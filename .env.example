# ============================================================
# VARIABLES DE ENTORNO - Marketo Supermercado
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# El archivo .env está en .gitignore y NUNCA se sube al repositorio.
#
# Para Cloudflare Pages: configurar estas variables en:
#   Cloudflare Dashboard → Pages → Tu proyecto → Settings → Environment variables
#
# Para GitHub Actions: configurar como Secrets en:
#   GitHub → Settings → Secrets and variables → Actions
# ============================================================

# URL base de tu proyecto Supabase
# Formato: https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima (anon key) de Supabase
# IMPORTANTE: Debe ser un JWT que comience con "eyJ..."
# La obtienes en: Supabase Dashboard → Settings → API → Project API keys → anon public
# Formato correcto: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIs...
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.TU_CLAVE_REAL_AQUI
